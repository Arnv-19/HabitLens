# HabitLens – Environment Variables Template
# Copy this file to .env in the repo root and fill in your values.
# NEVER commit the actual .env file – it is listed in .gitignore.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=habitlens
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=habitlens

DATABASE_URL=postgresql://habitlens:your_strong_password_here@db:5432/habitlens

# ── Backend ───────────────────────────────────────────────────────────────────
SECRET_KEY=your_jwt_secret_key_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── AI / Gemini ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
